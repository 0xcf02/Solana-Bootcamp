{
  "name": "Solana Bootcamp - SuperBank",
  "image": "mcr.microsoft.com/devcontainers/rust:1",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "iron-wallet.solana-wallet-adapter"
      ]
    }
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "curl --proto '=https' --tlsv1.2 -sSfL https://solana-install.solana.workers.dev | bash && echo 'source $HOME/.profile' >> ~/.bashrc"
}